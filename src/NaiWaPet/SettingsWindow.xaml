<Window x:Class="NaiWaPet.SettingsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="奶蛙桌宠设置"
        Width="460"
        Height="570"
        MinWidth="430"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FFF8E7"
        Icon="Assets/App/naiwa.png">
  <Window.Resources>
    <Style TargetType="CheckBox">
      <Setter Property="Margin" Value="0,9" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#3B2B16" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="MinWidth" Value="108" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Background" Value="#FFFFC947" />
      <Setter Property="BorderBrush" Value="#FFE09A00" />
      <Setter Property="Foreground" Value="#3B2B16" />
    </Style>
  </Window.Resources>

  <Grid Margin="26,22,26,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal">
      <Image Source="Assets/App/naiwa.png" Width="64" Height="64" Margin="0,0,14,0" />
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="奶蛙桌宠" FontSize="24" FontWeight="SemiBold" Foreground="#3B2B16" />
        <TextBlock Text="单击奶蛙即可播放完整捧腹大笑动作" Margin="0,4,0,0" Foreground="#806A42" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="1" Margin="0,18,0,12" Padding="18,14" Background="#FFFFFFFF" CornerRadius="12">
      <StackPanel>
        <DockPanel>
          <TextBlock Text="大小" FontSize="14" FontWeight="SemiBold" Foreground="#3B2B16" />
          <TextBlock x:Name="ScaleValueText" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="#806A42" />
        </DockPanel>
        <Slider x:Name="ScaleSlider"
                Margin="0,8,0,0"
                Minimum="0.5"
                Maximum="1.8"
                SmallChange="0.1"
                LargeChange="0.2"
                TickFrequency="0.1"
                IsSnapToTickEnabled="True"
                ValueChanged="OnScaleChanged" />
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Padding="18,8" Background="#FFFFFFFF" CornerRadius="12">
      <StackPanel>
        <CheckBox x:Name="SoundCheckBox" Content="播放原视频笑声（默认开启）" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
        <CheckBox x:Name="RoamingCheckBox" Content="偶尔在桌面上蹦一小步" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="始终显示在其他窗口上方" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
        <CheckBox x:Name="ClickThroughCheckBox" Content="鼠标穿透（开启后请用托盘图标操作）" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
        <CheckBox x:Name="StartupCheckBox" Content="登录 Windows 时自动启动" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
        <Separator Margin="0,9" />
        <TextBlock TextWrapping="Wrap" Foreground="#806A42" LineHeight="20">
          拖动奶蛙可移动；快速甩出会产生弹跳；滚轮可直接缩放；右键打开快捷菜单。所有设置只保存在本机。
        </TextBlock>
      </StackPanel>
    </Border>

    <DockPanel Grid.Row="3" Margin="0,14,0,0">
      <Button Content="重置位置" Click="OnResetPosition" DockPanel.Dock="Left" />
      <Button Content="播放一次" Click="OnPlay" DockPanel.Dock="Left" />
      <Button Content="完成" Click="OnDone" HorizontalAlignment="Right" IsDefault="True" />
    </DockPanel>
  </Grid>
</Window>

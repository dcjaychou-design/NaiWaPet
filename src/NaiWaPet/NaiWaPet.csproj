<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22000.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <RootNamespace>NaiWaPet</RootNamespace>
    <AssemblyName>NaiWaPet</AssemblyName>
    <ApplicationIcon>Assets\App\naiwa.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <DebugType>embedded</DebugType>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Product>奶蛙桌宠</Product>
    <Description>Windows 11 x64 透明奶蛙桌宠</Description>
    <Authors>dcjoker</Authors>
    <Copyright>Copyright © 2026 dcjoker</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NaiWaPet.Core\NaiWaPet.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Assets\Animation\**\*" />
    <None Remove="Assets\Audio\**\*" />
    <EmbeddedResource Include="Assets\Animation\**\*">
      <LogicalName>NaiWaPet.Assets.Animation.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Assets\Audio\laugh.wav">
      <LogicalName>NaiWaPet.Assets.Audio.laugh.wav</LogicalName>
    </EmbeddedResource>
    <Resource Include="Assets\App\naiwa.png" />
  </ItemGroup>
</Project>
